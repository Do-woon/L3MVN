# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# IDE/editor settings
.vscode/
.idea/
*.swp
*.swo
*~

# Notebook checkpoints
.ipynb_checkpoints/

